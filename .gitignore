# ============================================================================
# AutoBuddy - Git Ignore Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# SECRETS & ENVIRONMENT VARIABLES
# ----------------------------------------------------------------------------
# Never commit actual environment variables
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
**/.env.*.local

# Exception: Allow .env.example files
!.env.example
!**/.env.example

# Secrets and credentials
secrets/
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.keystore
*-key.json
service-account*.json
firebase-adminsdk*.json

# AWS credentials
.aws/
aws-credentials

# ----------------------------------------------------------------------------
# PYTHON / BACKEND
# ----------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
virtualenv/
*.egg-info/
dist/
build/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/
*.cover
.cache
nosetests.xml
coverage.xml

# Database files (local development)
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# Alembic
alembic/versions/*.pyc

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# PyCharm
.idea/
*.iml

# VS Code
.vscode/
*.code-workspace

# ----------------------------------------------------------------------------
# NODE.JS / FRONTEND / MOBILE
# ----------------------------------------------------------------------------
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak
yarn.lock.bak

# Build outputs
dist/
build/
.expo/
.expo-shared/
web-build/
*.jsbundle
*.jsbundle.map

# Metro bundler
.metro-health-check*

# Testing
coverage/
test-results/
*.lcov
junit.xml

# Expo
.expo/
.expo-shared/
expo-env.d.ts

# React Native
.buckconfig
.flowconfig
*.hprof

# ----------------------------------------------------------------------------
# LOGS
# ----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
backend.log
backend.err.log
smoke-backend.log
smoke-backend.err.log
expo.log
expo.err.log
memory/run-logs/
*.out.log

# ----------------------------------------------------------------------------
# DATABASES
# ----------------------------------------------------------------------------
# Local database files
*.db
*.sqlite
*.sqlite3
autobuddy_features.db
feature_test.db
backend.sqlite

# Database backups
*.sql.gz
*.dump
backup/

# ----------------------------------------------------------------------------
# DEPLOYMENT
# ----------------------------------------------------------------------------
.vercel/
.netlify/
.fly/

# Docker
docker-compose.override.yml
.dockerignore.local

# Terraform
*.tfstate
*.tfstate.*
.terraform/
*.tfvars

# Kubernetes secrets
*-secret.yaml
*-secrets.yaml

# ----------------------------------------------------------------------------
# TEMPORARY FILES
# ----------------------------------------------------------------------------
*.tmp
*.temp
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# Uploads (local development)
uploads/
temp/
tmp/

# ----------------------------------------------------------------------------
# IDE & EDITORS
# ----------------------------------------------------------------------------
# VS Code
.vscode/
*.code-workspace

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ----------------------------------------------------------------------------
# OPERATING SYSTEM
# ----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ----------------------------------------------------------------------------
# CERTIFICATES & KEYS
# ----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
*.keystore

# ----------------------------------------------------------------------------
# MONITORING & ANALYTICS
# ----------------------------------------------------------------------------
# Prometheus
prometheus_data/

# Grafana
grafana_data/

# ----------------------------------------------------------------------------
# MACHINE LEARNING
# ----------------------------------------------------------------------------
# Model files (large)
*.h5
*.pkl
*.joblib
*.model
*.weights

# Exception: Allow small example models
!example-model.h5

# Training data (large)
data/training/
data/raw/
*.csv.gz
*.parquet

# TensorBoard
runs/
logs/tensorboard/

# ----------------------------------------------------------------------------
# MISCELLANEOUS
# ----------------------------------------------------------------------------
# Backup files
*.bak
*.backup
*.old

# Archive files
*.zip
*.tar.gz
*.rar
*.7z

# Compiled source
*.com
*.class
*.dll
*.exe
*.o
*.so

# ----------------------------------------------------------------------------
# PROJECT-SPECIFIC
# ----------------------------------------------------------------------------
# Linting outputs
lint-output.txt
lint-results.txt
lint-full.txt
full-lint.txt
temp-lint.txt

# Test outputs
test-output/
test-results/

# Build artifacts
*.apk
*.aab
*.ipa

# ----------------------------------------------------------------------------
# KEEP THESE FILES
# ----------------------------------------------------------------------------
# These are intentionally NOT ignored:
# !.env.example
# !.env.sample
# !.gitkeep
# !README.md
# !LICENSE

# ============================================================================
