# ============================================================================
# AutoBuddy Mobile App Configuration
# ============================================================================
# Copy this file to .env and replace placeholder values with real credentials
# NEVER commit the actual .env file to version control
# ============================================================================

# ----------------------------------------------------------------------------
# BACKEND API CONFIGURATION
# ----------------------------------------------------------------------------
# Development: Use your local machine's LAN IP (not localhost for physical devices)
# Find your IP:
#   Windows: ipconfig (look for IPv4 Address)
#   Mac/Linux: ifconfig or ip addr
# Examples:
#   - Local development: http://192.168.1.100:8001/api
#   - Staging: https://staging-api.autobuddy.app/api
#   - Production: https://api.autobuddy.app/api

EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:8001/api

# ----------------------------------------------------------------------------
# WEBSOCKET CONFIGURATION
# ----------------------------------------------------------------------------
# Socket.IO endpoint for real-time features (live tracking, notifications)
# If not specified, will default to same host as API_BASE_URL

# EXPO_PUBLIC_SOCKET_BASE_URL=http://192.168.1.100:8001
# EXPO_PUBLIC_SOCKET_PATH=/ws/socket.io
# EXPO_PUBLIC_SOCKET_TRANSPORTS=websocket,polling

# Socket connection settings
EXPO_PUBLIC_SOCKET_RECONNECTION=true
EXPO_PUBLIC_SOCKET_RECONNECTION_ATTEMPTS=5
EXPO_PUBLIC_SOCKET_RECONNECTION_DELAY=1000

# ----------------------------------------------------------------------------
# GOOGLE SERVICES
# ----------------------------------------------------------------------------
# Google Maps API Key (with Maps SDK + Places API enabled)
# Required for:
#   - Map display (iOS, Android, Web)
#   - Place autocomplete
#   - Geocoding
#   - Route display

EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google OAuth 2.0 Client IDs (for Google Sign-In)
# Get these from Google Cloud Console → APIs & Services → Credentials
# Create OAuth 2.0 Client IDs for each platform

# Expo client ID (for development with Expo Go)
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=your_expo_google_oauth_client_id.apps.googleusercontent.com

# Android client ID (for production Android app)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_google_oauth_client_id.apps.googleusercontent.com

# iOS client ID (for production iOS app)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_google_oauth_client_id.apps.googleusercontent.com

# Web client ID (for web build)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_google_oauth_client_id.apps.googleusercontent.com

# ----------------------------------------------------------------------------
# STRIPE PAYMENT
# ----------------------------------------------------------------------------
# Stripe Publishable Key (safe for client-side use)
# Get from: https://dashboard.stripe.com/apikeys
# Use test key (pk_test_...) for development
# Use live key (pk_live_...) for production

EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Stripe Configuration
EXPO_PUBLIC_STRIPE_MERCHANT_ID=your_apple_merchant_id  # For Apple Pay (iOS)

# ----------------------------------------------------------------------------
# FIREBASE (Push Notifications, Analytics)
# ----------------------------------------------------------------------------
# Firebase configuration for push notifications
# Get from Firebase Console → Project Settings → General

# Android
EXPO_PUBLIC_FIREBASE_API_KEY_ANDROID=your_android_firebase_api_key
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID_ANDROID=your_android_app_id

# iOS
EXPO_PUBLIC_FIREBASE_API_KEY_IOS=your_ios_firebase_api_key
EXPO_PUBLIC_FIREBASE_APP_ID_IOS=your_ios_app_id

# Web
EXPO_PUBLIC_FIREBASE_API_KEY_WEB=your_web_firebase_api_key
EXPO_PUBLIC_FIREBASE_APP_ID_WEB=your_web_app_id

# ----------------------------------------------------------------------------
# SENTRY (Error Tracking & Performance Monitoring)
# ----------------------------------------------------------------------------
# Sentry DSN for error tracking
# Get from: Sentry.io → Project Settings → Client Keys (DSN)

EXPO_PUBLIC_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development  # development, staging, production

# Sentry Configuration
EXPO_PUBLIC_SENTRY_ENABLED=true
EXPO_PUBLIC_SENTRY_TRACE_SAMPLE_RATE=0.1  # 10% of transactions
EXPO_PUBLIC_SENTRY_DEBUG=false  # Set to true for debugging Sentry itself

# ----------------------------------------------------------------------------
# FACEBOOK & SOCIAL LOGIN
# ----------------------------------------------------------------------------
# Facebook App ID (for Facebook Login)
# Get from: https://developers.facebook.com/apps/

EXPO_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id
EXPO_PUBLIC_FACEBOOK_CLIENT_TOKEN=your_facebook_client_token
EXPO_PUBLIC_FACEBOOK_DISPLAY_NAME=AutoBuddy

# Other social platforms
# EXPO_PUBLIC_TWITTER_API_KEY=your_twitter_api_key
# EXPO_PUBLIC_APPLE_SERVICE_ID=your_apple_service_id

# ----------------------------------------------------------------------------
# APP CONFIGURATION
# ----------------------------------------------------------------------------
# App environment
EXPO_PUBLIC_ENVIRONMENT=development  # development, staging, production

# App behavior
EXPO_PUBLIC_ENABLE_LOGGING=true  # Verbose logging for development
EXPO_PUBLIC_ENABLE_REDUX_DEVTOOLS=false
EXPO_PUBLIC_API_TIMEOUT=30000  # API request timeout in ms

# Feature flags (enable/disable features remotely)
EXPO_PUBLIC_ENABLE_VOICE_BOOKING=true
EXPO_PUBLIC_ENABLE_AI_TRAVEL_INTENT=true
EXPO_PUBLIC_ENABLE_RIDE_POOLING=true
EXPO_PUBLIC_ENABLE_SCHEDULED_RIDES=true
EXPO_PUBLIC_ENABLE_BIOMETRIC_AUTH=true
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true

# ----------------------------------------------------------------------------
# MAP CONFIGURATION
# ----------------------------------------------------------------------------
# Map provider
EXPO_PUBLIC_MAP_PROVIDER=google  # Options: google, mapbox, osm

# Mapbox (alternative to Google Maps)
# EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_token

# Map settings
EXPO_PUBLIC_MAP_DEFAULT_ZOOM=15
EXPO_PUBLIC_MAP_DEFAULT_LATITUDE=12.9716
EXPO_PUBLIC_MAP_DEFAULT_LONGITUDE=77.5946  # Bangalore, India

# Live tracking
EXPO_PUBLIC_LOCATION_UPDATE_INTERVAL=5000  # ms between location updates
EXPO_PUBLIC_LOCATION_ACCURACY=high  # high, balanced, low

# ----------------------------------------------------------------------------
# PAYMENT METHODS
# ----------------------------------------------------------------------------
# Enable/disable payment methods
EXPO_PUBLIC_ENABLE_CARD_PAYMENT=true
EXPO_PUBLIC_ENABLE_UPI_PAYMENT=true
EXPO_PUBLIC_ENABLE_WALLET_PAYMENT=true
EXPO_PUBLIC_ENABLE_CASH_PAYMENT=true
EXPO_PUBLIC_ENABLE_APPLE_PAY=true
EXPO_PUBLIC_ENABLE_GOOGLE_PAY=true

# Default payment method
EXPO_PUBLIC_DEFAULT_PAYMENT_METHOD=card  # card, upi, wallet, cash

# ----------------------------------------------------------------------------
# UI/UX CONFIGURATION
# ----------------------------------------------------------------------------
# Theme
EXPO_PUBLIC_THEME=light  # light, dark, auto
EXPO_PUBLIC_PRIMARY_COLOR=#4CAF50
EXPO_PUBLIC_ACCENT_COLOR=#FF9800

# Language & Localization
EXPO_PUBLIC_DEFAULT_LANGUAGE=en  # en, es, fr, hi, ta, te
EXPO_PUBLIC_CURRENCY=INR
EXPO_PUBLIC_CURRENCY_SYMBOL=₹
EXPO_PUBLIC_DISTANCE_UNIT=km  # km, miles

# Accessibility
EXPO_PUBLIC_ENABLE_HAPTIC_FEEDBACK=true
EXPO_PUBLIC_ENABLE_SOUND_EFFECTS=true
EXPO_PUBLIC_ENABLE_HIGH_CONTRAST=false

# ----------------------------------------------------------------------------
# ANALYTICS & TRACKING
# ----------------------------------------------------------------------------
# Analytics provider
EXPO_PUBLIC_ANALYTICS_ENABLED=true
EXPO_PUBLIC_ANALYTICS_PROVIDER=firebase  # firebase, mixpanel, amplitude

# Mixpanel (alternative analytics)
# EXPO_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token

# Amplitude
# EXPO_PUBLIC_AMPLITUDE_API_KEY=your_amplitude_key

# Google Analytics (for web)
EXPO_PUBLIC_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Privacy settings
EXPO_PUBLIC_TRACK_USER_LOCATION=true
EXPO_PUBLIC_TRACK_USER_BEHAVIOR=true
EXPO_PUBLIC_ALLOW_PERSONALIZED_ADS=false

# ----------------------------------------------------------------------------
# PUSH NOTIFICATIONS
# ----------------------------------------------------------------------------
# Expo Push Notifications
EXPO_PUBLIC_EXPO_PROJECT_ID=your_expo_project_id

# OneSignal (alternative push notification service)
# EXPO_PUBLIC_ONESIGNAL_APP_ID=your_onesignal_app_id

# Notification settings
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_IN_APP_NOTIFICATIONS=true
EXPO_PUBLIC_NOTIFICATION_SOUND=default

# ----------------------------------------------------------------------------
# DEEP LINKING
# ----------------------------------------------------------------------------
# URL scheme for deep linking
EXPO_PUBLIC_URL_SCHEME=autobuddy
EXPO_PUBLIC_DEEP_LINK_PREFIX=autobuddy://

# Universal links (iOS) and App Links (Android)
EXPO_PUBLIC_UNIVERSAL_LINK_DOMAIN=app.autobuddy.com

# ----------------------------------------------------------------------------
# PERFORMANCE & OPTIMIZATION
# ----------------------------------------------------------------------------
# API caching
EXPO_PUBLIC_ENABLE_API_CACHE=true
EXPO_PUBLIC_CACHE_TTL=300000  # 5 minutes in ms

# Image caching
EXPO_PUBLIC_ENABLE_IMAGE_CACHE=true
EXPO_PUBLIC_IMAGE_CACHE_SIZE_MB=100

# Data persistence
EXPO_PUBLIC_ENABLE_OFFLINE_CACHE=true
EXPO_PUBLIC_MAX_OFFLINE_CACHE_SIZE_MB=50

# Performance monitoring
EXPO_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true
EXPO_PUBLIC_PERFORMANCE_SAMPLE_RATE=0.1  # 10% of users

# ----------------------------------------------------------------------------
# SECURITY
# ----------------------------------------------------------------------------
# Security settings
EXPO_PUBLIC_ENABLE_SSL_PINNING=false  # Set to true in production
EXPO_PUBLIC_ENABLE_ROOT_DETECTION=false  # Detect rooted/jailbroken devices
EXPO_PUBLIC_ENABLE_DEBUG_BLOCK=false  # Block app if debugger detected (production)

# Biometric authentication
EXPO_PUBLIC_BIOMETRIC_PROMPT_TITLE=Authenticate
EXPO_PUBLIC_BIOMETRIC_PROMPT_SUBTITLE=Use biometric to authenticate

# Session management
EXPO_PUBLIC_SESSION_TIMEOUT_MINUTES=30
EXPO_PUBLIC_AUTO_LOGOUT_ON_BACKGROUND=false

# ----------------------------------------------------------------------------
# DEVELOPMENT & DEBUGGING
# ----------------------------------------------------------------------------
# Development mode
EXPO_PUBLIC_DEV_MODE=true
EXPO_PUBLIC_SHOW_DEV_MENU=true
EXPO_PUBLIC_ENABLE_HOT_RELOAD=true

# API mocking (for development without backend)
EXPO_PUBLIC_USE_MOCK_API=false
EXPO_PUBLIC_MOCK_API_DELAY=1000  # Simulate network delay in ms

# Debugging
EXPO_PUBLIC_ENABLE_CONSOLE_LOGS=true
EXPO_PUBLIC_ENABLE_NETWORK_LOGGING=false
EXPO_PUBLIC_ENABLE_REDUX_LOGGING=false

# Expo DevClient
EXPO_PUBLIC_DEV_CLIENT_ENABLED=false

# ----------------------------------------------------------------------------
# BUILD CONFIGURATION
# ----------------------------------------------------------------------------
# App versioning
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_BUILD_NUMBER=1

# Store URLs (for rate/review prompts)
EXPO_PUBLIC_IOS_APP_STORE_ID=your_ios_app_id
EXPO_PUBLIC_ANDROID_PACKAGE_NAME=com.autobuddy.app

# ----------------------------------------------------------------------------
# LEGAL & COMPLIANCE
# ----------------------------------------------------------------------------
# Terms and policies
EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://autobuddy.com/terms
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://autobuddy.com/privacy
EXPO_PUBLIC_SUPPORT_EMAIL=support@autobuddy.com
EXPO_PUBLIC_SUPPORT_PHONE=+1-800-AUTOBUDDY

# ----------------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------------
# 1. All EXPO_PUBLIC_* variables are embedded in the app bundle at build time
# 2. Never include secret keys that should remain server-side
# 3. For physical device testing, use your computer's LAN IP in API_BASE_URL
# 4. Update Firebase, Google, and Stripe keys for each environment
# 5. Set ENVIRONMENT=production and disable debug flags for production builds
# 6. Rotate OAuth client IDs and API keys regularly
# 7. Test all payment methods in Stripe test mode before going live
# 8. Verify deep links work on both iOS and Android before release
# ============================================================================
