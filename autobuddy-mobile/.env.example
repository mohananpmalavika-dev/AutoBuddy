# Use your computer's LAN IP for physical devices (example: http://192.168.29.101:8001/api)
EXPO_PUBLIC_API_BASE_URL=http://YOUR_LAN_IP:8001/api
# Use one Google key with Places API + Maps SDK for Android enabled.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key_here
# Google OAuth client IDs for direct Google sign-in.
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=your_expo_client_id_here
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id_here
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id_here
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id_here
