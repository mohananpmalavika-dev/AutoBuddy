{
  "buildCommand": "node ./node_modules/expo/bin/cli export --platform web && cp public/index.html dist/index.html",
  "outputDirectory": "dist",
  "routes": [
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/app(/.*)?$", "dest": "/app/index.html" },
    { "src": "^/api/(.*)$", "dest": "https://autobuddy-z1vx.onrender.com/api/$1" },
    { "src": "^/(.*)$", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
      ]
    }
  ],
  "env": { 
    "EXPO_PUBLIC_API_BASE_URL": "https://autobuddy-z1vx.onrender.com/api",
    "EXPO_PUBLIC_SOCKET_BASE_URL": "https://autobuddy-z1vx.onrender.com",
    "EXPO_PUBLIC_SOCKET_PATH": "/ws/socket.io",
    "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "475485627719-lgd8c3sgr1d5unie68d2qjcifjoolt5f.apps.googleusercontent.com"
  }
}
