{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": false,
    "types": ["node"],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ]
    }
  },
  "include": [
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/screens/index.ts",
    "src/screens/types.ts",
    "src/screens/DriverDashboard.ts",
    "src/screens/PassengerMap.ts",
    "src/lib/api.ts",
    "src/lib/api-client.ts",
    "src/lib/auth.ts",
    "src/lib/authSession.ts",
    "src/lib/backgroundNotificationService.js",
    "src/lib/models.ts",
    "src/lib/navigation.ts",
    "src/lib/paymentOptions.js",
    "src/lib/persistentSessionManager.js",
    "src/lib/session.js",
    "src/lib/subscriptions.ts",
    "src/contexts/AppStateProvider.tsx",
    "src/components/animated-icon.tsx",
    "src/components/animated-icon.web.tsx",
    "src/components/RealtimeNotificationHost.tsx",
    "src/components/VoiceTextInput.tsx",
    "src/components/WebCommandBar.tsx",
    "src/components/PremiumCard.tsx",
    "src/components/app/**/*.tsx",
    "src/theme.d.ts",
    "**/*.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "jest.setup.ts",
    "App.tsx",
    "**/*.test.ts",
    "**/*.test.tsx",
    "src/App.tsx",
    "src/AppShell.tsx"
  ]
}
